# R2 Data mirror.
neutrino/
soundfonts/

# Claude Code: personal overrides and local state.
#
# The project-level .claude/settings.json is checked in and shared with
# the team. Anything personal belongs in the files below and must not
# be committed.
.claude/settings.local.json
.claude/*.local.json
.claude/sessions/
.claude/history/
.claude/cache/

# Environment variables and secrets.
.env
.env.local
.env.*.local

# OS and editor cruft.
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json

# Node / pnpm
node_modules/
.pnpm-store/

# Frontend build output
frontend/dist/
frontend/.vite/

# GAS compiled output (clasp pushes src/ directly as TypeScript)
gas/dist/
gas/.clasp.json.local

# Pipeline generated artifacts (never committed)
# projects/**/output/ covers both projects/{slug}/output/ (legacy) and
# projects/{slug}/versions/{version}/output/ (current nested structure)
projects/**/output/
artifacts/

# Frontend generated assets — produced by 06_merge_songs.py (CI) or
# scripts/dev-populate.py (local dev).  Never hand-edit or commit.
frontend/public/audio/
frontend/public/scores/

# songs.json is generated at build time (CI: 06_merge_songs.py; local dev:
# scripts/dev-populate.py).  The committed state is [] (empty array) which
# serves as the fallback when neither script has run.  After running
# dev-populate locally, reset it with: git restore frontend/src/data/songs.json
# (NOT gitignored — Vite needs it to exist at dev-server startup.)

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
