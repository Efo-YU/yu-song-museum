    "page_config": {
      "theme": {
        "primary_color": "#5c3a8a"
      },
      "description_markdown": "1938年（昭和13年）に制定された山形高等学校の校歌。作詞は山形高等学校教授で英文学者の島村苳三（盛助）、作曲はオルガン奏者の大中寅二によるもの。",
      "source": "山形高等学校学寮史編纂委員会編『学寮史』（山形高等学校学寮史刊行会、1938年）366〜367頁",
      "lyrics": [
        {
          "number": 1,
          "lines": [
            "われらここに聚ふ",
            "わがまなびやは",
            "ひいでたる山のすがた",
            "にごらざる水のながれ",
            "たぐひなし",
            "ああわがまなびや",
            "われらここに聚ふ"
          ]
        },
        {
          "number": 2,
          "lines": [
            "われらここに仰ぐ",
            "われらが則は",
            "若人のきよきこころ",
            "健かにおほしたてなむ",
            "もとゐなり",
            "ああこの綱領",
            "われらここに仰ぐ"
          ]
        },
        {
          "number": 3,
          "lines": [
            "われらここに歩む",
            "学びのみちは",
            "とこしへの真理たづね",
            "あらたなる知識もとめ",
            "きはみなし",
            "ひとすぢたゆまず",
            "われらここに歩む"
          ]
        },
        {
          "number": 4,
          "lines": [
            "われらここに盟ふ",
            "はらからわれら",
            "日本の国の光輝",
            "万邦の民の平和",
            "まもるべし",
            "五百のはらから",
            "われらここに盟ふ"
          ]
        }
      ],
