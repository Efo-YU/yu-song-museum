  {
    "slug": "yonezawa-kogyo-kouka",
    "title": "米沢高等工業学校校歌",
    "bpm": 120,
    "key": "C major",
    "credits": {
      "vocalist": "MERROW (NEUTRINO)",
      "lyricist": "土井晩翠",
      "composer": "松平信博"
    },
    "page_config": {
      "theme": {
        "primary_color": "#c0392b"
      },
      "description_markdown": "1926年（大正15年）に制定された米沢高等工業学校の校歌。作詞は山形県師範学校校歌も手掛けた土井晩翠、作曲は「殿様作曲家」と呼ばれた松平信博によるもの。",
      "source": "山形大学工学部50年史編集委員会編『山形大学工学部50年史』（山形大学工学部50周年記念会、1960年）52頁",
      "lyrics": [
        {
          "number": 1,
          "lines": [
            "誉の名君治めし勲",
            "余韻は絶えせしとこしへ遠く",
            "勤倹習ひとなりたる此の地",
            "新たの時世に新たの光添へ得つ高等工業校舎"
          ]
        },
        {
          "number": 2,
          "lines": [
            "明治の聖代四十と三を数へし其の年",
            "基を置きてはくくみ来りし子弟の栄",
            "今将た貢献四海の上に",
            "教をしきゆく富国の道に"
          ]
        },
        {
          "number": 3,
          "lines": [
            "吾妻は聳えて高きをさとし",
            "松川流れて遠きを示す",
            "其の山其の水仰きて伏して",
            "朝夕無言の教へに浸り",
            "希望の溢るる数百の健児"
          ]
        },
        {
          "number": 4,
          "lines": [
            "金剛堅かれ心の誠",
            "身を立て名を揚け東亜の空に",
            "光と照るへく進みて励め",
            "青春勇みの吾か世の門出",
            "誉は伝へん無窮の末に"
          ]
        }
      ],
      "downloads": {
