      "source": "鶴岡郷土史研究会『会報』第22号（2015年）所収 vol22_shoyoka.pdf",
      "lyrics": [
        {
          "number": 1,
          "lines": [
            "庄内の野の果遠く",
            "稲穂垂るる秋は来たりて",
            "香ぐはしき思想（おもい）ほのめき",
            "新しき文化したう我等"
          ]
        },
        {
          "number": 2,
          "lines": [
            "豊かなる情緒（こころ）の潮",
            "清けらく平らけくあれや",
            "若人の胸にしみ入る",
            "遥かなる高き理想文化"
          ]
        },
        {
          "number": 3,
          "lines": [
            "我等今ここに集いて",
            "なごやかに歌を合せん",
            "心よき友達来たり",
            "にぎはしく心楽しや宴"
          ]
        }
      ],
