          "遥かなる高き理想文化"
        ]
      },
      {
        "number": 3,
        "lines": [
          "我等今ここに集いて",
          "なごやかに歌を合せん",
          "心よき友達来たり",
          "にぎはしく心楽しや宴"
        ]
      }
